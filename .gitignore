# npm dependencies (regenerate with `cd tools && npm install`)
node_modules/

# Ephemeral capture intermediates
# tools/frames/    — 150+ PNGs per run, regen: `node tools/capture.mjs --video-frames`
# tools/captions/  — caption PNGs, regen: `tools/build-video.sh`
tools/frames/
tools/captions/

# Third-party YouTube audio downloads (~240 MB, copyrighted, can be re-fetched
# with `./tools/yt-dlp -f "bestaudio[ext=m4a]"`).
tools/audio/

# Downloaded tool binaries (fetch fresh from GitHub release on demand)
tools/yt-dlp
tools/bin/

# OS junk
.DS_Store
Thumbs.db
*.swp
